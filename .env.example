# --- Privy (embedded auth + wallet) ---
NEXT_PUBLIC_PRIVY_APP_ID=
# Optional — only needed if you verify Privy auth tokens server-side
PRIVY_VERIFICATION_KEY=

# --- Solana RPC (devnet by default; use Helius/QuickNode for reliability) ---
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# --- ElevenLabs (AI audio tools: noise removal / voice isolation) ---
ELEVENLABS_API_KEY=

# --- Irys / Arweave permanent storage ---
# No key needed for devnet — the connected wallet funds and signs uploads.
# Set this only if you want a server-side funded node instead of per-user funding.
IRYS_SERVER_PRIVATE_KEY=
