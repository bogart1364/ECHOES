# --- Privy (embedded auth + wallet) ---
NEXT_PUBLIC_PRIVY_APP_ID=
# Optional — only needed if you verify Privy auth tokens server-side
PRIVY_VERIFICATION_KEY=

# --- Solana RPC (devnet by default; use Helius/QuickNode for reliability) ---
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# --- ElevenLabs (AI audio tools: noise removal / voice isolation) ---
ELEVENLABS_API_KEY=

# --- Vercel Blob (audio/cover image storage) ---
# On Vercel: connect a Blob store to the project (Storage tab → Create
# Database → Blob) and this is auto-injected — no manual value needed.
# For local dev, copy the token from the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=
